{
  "name": "taskmaster-pro",
  "version": "1.0.0",
  "description": "MVP de gestión de tareas corporativas (Clean Architecture, Express, Prisma, SQLite)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
